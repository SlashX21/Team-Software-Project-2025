# Grocery Guardian - Environment Configuration Template
# Copy this file to .env and update the values according to your setup
# Command: cp .env.example .env

# ============================================
# 🚨 CRITICAL: Environment Configuration
# ============================================
# IMPORTANT: AI Recommendation Service requires ENVIRONMENT=local
# DO NOT use 'development' - it will cause startup failures
ENVIRONMENT=local

# ============================================
# 🗄️ Database Configuration
# ============================================
DB_NAME=springboot_demo
DB_USERNAME=root
DB_PASSWORD=20020213Lx
DB_HOST=localhost
DB_PORT=3306

# ============================================
# 🌐 Service Port Configuration
# ============================================
BACKEND_PORT=8080
RECOMMENDATION_SERVICE_PORT=8001
OCR_SERVICE_PORT=8000

# ============================================
# 🤖 AI Service Configuration
# ============================================
# For development, you can use the mock key below
# For production, replace with your actual OpenAI API key
OPENAI_API_KEY=sk-test-mock-key-for-local-development

# Azure OpenAI Configuration (if using Azure instead of OpenAI)
AZURE_ENDPOINT=https://grocery-guardian.cognitiveservices.azure.com
AZURE_KEY=your_actual_azure_key_here

# ============================================
# �� Configuration Notes
# ============================================
# - ENVIRONMENT must be one of: local, azure, testing
# - For local development, use ENVIRONMENT=local
# - Default MySQL credentials are set for local development
# - Update OPENAI_API_KEY with your actual key for full functionality
# - All ports can be customized but ensure they don't conflict with other services

# ============================================
# 🚀 Quick Start
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Update your actual API keys in .env
# 3. Run: ./start_all_services.sh
# 4. Access: http://localhost:8080 (Backend) | http://localhost:8001 (AI Service)
