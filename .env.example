# ============================================
# Grocery Guardian 环境配置模板
# ============================================
# 复制此文件为 .env 并填入真实的配置值

# ============================================
# 数据库配置
# ============================================
DB_NAME=springboot_demo
DB_USERNAME=root
DB_PASSWORD=your_database_password_here
DB_HOST=localhost
DB_PORT=3306

# ============================================
# 微服务端口配置
# ============================================
BACKEND_PORT=8080
OCR_SERVICE_PORT=8000
RECOMMENDATION_SERVICE_PORT=8001

# ============================================
# AI服务配置
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
AZURE_ENDPOINT=https://your-azure-endpoint.cognitiveservices.azure.com
AZURE_KEY=your-azure-cognitive-services-key-here
API_TOKEN=your-api-token-here

# ============================================
# 环境标识
# ============================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# 安全配置
# ============================================
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_long
JWT_EXPIRATION=86400
