# Grocery Guardian 项目环境配置
# 前端测试配置

# 环境设置
FLUTTER_APP_ENV=development
ENVIRONMENT=local

# API配置  
FLUTTER_API_BASE_URL=http://localhost:8080/api/v1
BACKEND_PORT=8080
OCR_SERVICE_PORT=8000
RECOMMENDATION_SERVICE_PORT=8001

# 日志配置
LOG_LEVEL=DEBUG

# ============================================
# 数据库配置 - 修复登录转圈问题
# ============================================
DATABASE_URL=jdbc:mysql://localhost:3306/springboot_demo?createDatabaseIfNotExist=true&charset=utf8mb4&serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=springboot_demo
DB_USERNAME=root
DB_PASSWORD=20020213Lx

# ============================================
# AI服务配置
# ============================================
OPENAI_API_KEY=test_key

# ============================================
# Python推荐系统数据库连接字符串
# ============================================
JAVA_DB_CONNECTION_STRING=mysql+pymysql://root:20020213Lx@localhost:3306/springboot_demo?charset=utf8mb4

# ============================================
# 微服务配置
# ============================================
OCR_SERVICE_URL=http://localhost:8000
RECOMMENDATION_SERVICE_URL=http://localhost:8001
API_TOKEN=123456
